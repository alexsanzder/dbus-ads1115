#!/bin/sh
# dbus-ads1115 service run script

exec 2>&1

# I2C hardware initialization - do NOT load kernel driver
# The ti-ads1015 kernel driver has multiplexing issues that cause
# unstable readings when switching channels. Use direct SMBus instead.
if [ -d /sys/bus/i2c/devices/i2c-1 ]; then
    # Ensure kernel driver is unloaded if it was loaded
    rmmod ti_ads1015 2>/dev/null
    
    # Register the device for SMBus access (without kernel driver)
    if [ ! -d /sys/bus/i2c/devices/1-0048 ]; then
        echo ads1115 0x48 > /sys/bus/i2c/devices/i2c-1/new_device
        sleep 1
    fi
fi

# Start Python service
cd /data/dbus-ads1115
exec python3 -u -m dbus_ads1115.dbus_ads1115 -c config.ini
